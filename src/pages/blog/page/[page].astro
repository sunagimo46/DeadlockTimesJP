---
import Layout from "../../../layouts/Layout.astro"
import BlogCardList from "../../../components/BlogCardList.astro"
import CategoryFilter from "../../../components/CategoryFilter.astro"
import Pagination from "../../../components/Pagination.astro"
import { getPublishedPosts, sortPostsByDate } from "../../../lib/posts"
import { POSTS_PER_PAGE } from "../../../lib/constants"

export async function getStaticPaths() {
  const allPosts = await getPublishedPosts()
  const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE)

  return Array.from({ length: totalPages - 1 }, (_, i) => ({
    params: { page: String(i + 2) },
  }))
}

const page = Number(Astro.params.page)
const allPosts = await getPublishedPosts()
const sortedPosts = sortPostsByDate(allPosts)
const totalPages = Math.ceil(sortedPosts.length / POSTS_PER_PAGE)
const start = (page - 1) * POSTS_PER_PAGE
const pagedPosts = sortedPosts.slice(start, start + POSTS_PER_PAGE)
---

<Layout title={`記事一覧 - ページ${page}`}>
  <h1 class="text-3xl font-bold mb-8">記事一覧</h1>

  <CategoryFilter />

  <BlogCardList posts={pagedPosts} />

  <Pagination currentPage={page} lastPage={totalPages} baseUrl="/blog" />
</Layout>
