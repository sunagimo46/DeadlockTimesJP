---
import Layout from "../../../../layouts/Layout.astro"
import BlogCardList from "../../../../components/BlogCardList.astro"
import Breadcrumb from "../../../../components/Breadcrumb.astro"
import Pagination from "../../../../components/Pagination.astro"
import { getPublishedPosts, sortPostsByDate } from "../../../../lib/posts"
import { POSTS_PER_PAGE } from "../../../../lib/constants"

export async function getStaticPaths() {
  const allPosts = await getPublishedPosts()
  const uniqueTags = [...new Set(allPosts.flatMap((post) => post.data.tags))]

  return uniqueTags.flatMap((tag) => {
    const filteredPosts = allPosts.filter((post) =>
      post.data.tags.includes(tag),
    )
    const totalPages = Math.ceil(filteredPosts.length / POSTS_PER_PAGE)

    return Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => ({
      params: { tag, page: String(i + 2) },
    }))
  })
}

const { tag, page: pageParam } = Astro.params
const page = Number(pageParam)

const allPosts = await getPublishedPosts()
const sortedPosts = sortPostsByDate(
  allPosts.filter((post) => post.data.tags.includes(tag)),
)
const totalPages = Math.ceil(sortedPosts.length / POSTS_PER_PAGE)
const start = (page - 1) * POSTS_PER_PAGE
const pagedPosts = sortedPosts.slice(start, start + POSTS_PER_PAGE)
---

<Layout
  title={`「${tag}」タグの記事一覧 - ページ${page}`}
  description={`Deadlock攻略ブログの「${tag}」タグが付けられた記事の一覧です。`}
>
  <Breadcrumb
    items={[
      { name: "ホーム", href: "/" },
      { name: "記事一覧", href: "/blog" },
      { name: `タグ: ${tag}`, href: `/blog/tags/${tag}` },
      { name: `ページ${page}` },
    ]}
  />

  <h1 class="text-3xl font-bold mb-8">
    タグ: <span class="text-accent">{tag}</span>
  </h1>

  <BlogCardList posts={pagedPosts} />

  <Pagination
    currentPage={page}
    lastPage={totalPages}
    baseUrl={`/blog/tags/${tag}`}
  />
</Layout>
