---
import Layout from "../../../../layouts/Layout.astro"
import BlogCardList from "../../../../components/BlogCardList.astro"
import Breadcrumb from "../../../../components/Breadcrumb.astro"
import Pagination from "../../../../components/Pagination.astro"
import { getPublishedPosts, sortPostsByDate } from "../../../../lib/posts"
import {
  ALL_CATEGORIES,
  CATEGORY_LABELS,
  CATEGORY_DESCRIPTIONS,
  SITE_NAME,
  POSTS_PER_PAGE,
} from "../../../../lib/constants"

export async function getStaticPaths() {
  const allPosts = await getPublishedPosts()

  return ALL_CATEGORIES.flatMap((category) => {
    const filteredPosts = allPosts.filter(
      (post) => post.data.category === category,
    )
    const totalPages = Math.ceil(filteredPosts.length / POSTS_PER_PAGE)

    return Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => ({
      params: { category, page: String(i + 2) },
    }))
  })
}

const { category, page: pageParam } = Astro.params
const page = Number(pageParam)
const categoryLabel = CATEGORY_LABELS[category] ?? category
const categoryDescription = CATEGORY_DESCRIPTIONS[category] ?? ""

const allPosts = await getPublishedPosts()
const sortedPosts = sortPostsByDate(
  allPosts.filter((post) => post.data.category === category),
)
const totalPages = Math.ceil(sortedPosts.length / POSTS_PER_PAGE)
const start = (page - 1) * POSTS_PER_PAGE
const pagedPosts = sortedPosts.slice(start, start + POSTS_PER_PAGE)
---

<Layout
  title={`${categoryLabel}の記事一覧 - ページ${page}`}
  description={`${SITE_NAME}の${categoryLabel}カテゴリの記事一覧。${categoryDescription}`}
>
  <Breadcrumb
    items={[
      { name: "ホーム", href: "/" },
      { name: "記事一覧", href: "/blog" },
      { name: categoryLabel, href: `/blog/category/${category}` },
      { name: `ページ${page}` },
    ]}
  />

  <h1 class="text-3xl font-bold mb-4">{categoryLabel}</h1>
  <p class="text-text-secondary mb-8">{categoryDescription}</p>

  <BlogCardList posts={pagedPosts} />

  <Pagination
    currentPage={page}
    lastPage={totalPages}
    baseUrl={`/blog/category/${category}`}
  />
</Layout>
