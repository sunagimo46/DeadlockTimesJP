---
import Layout from "../../../layouts/Layout.astro"
import BlogCard from "../../../components/BlogCard.astro"
import Breadcrumb from "../../../components/Breadcrumb.astro"
import { getCollection } from "astro:content"
import {
  ALL_CATEGORIES,
  CATEGORY_LABELS,
  CATEGORY_DESCRIPTIONS,
} from "../../../lib/constants"

export async function getStaticPaths() {
  return ALL_CATEGORIES.map((category) => ({
    params: { category },
  }))
}

const { category } = Astro.params
const categoryLabel = CATEGORY_LABELS[category] ?? category
const categoryDescription = CATEGORY_DESCRIPTIONS[category] ?? ""

const allPosts = await getCollection("blog", ({ data }) => {
  const isPublished = import.meta.env.PROD ? data.draft !== true : true
  return isPublished && data.category === category
})

const sortedPosts = [...allPosts].sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
)
---

<Layout
  title={`${categoryLabel}の記事一覧`}
  description={`Deadlock攻略ブログの${categoryLabel}カテゴリの記事一覧。${categoryDescription}`}
>
  <Breadcrumb
    items={[
      { name: "ホーム", href: "/" },
      { name: "記事一覧", href: "/blog" },
      { name: categoryLabel },
    ]}
  />

  <h1 class="text-3xl font-bold mb-4">{categoryLabel}</h1>
  <p class="text-text-secondary mb-8">{categoryDescription}</p>

  {
    sortedPosts.length === 0 ? (
      <p class="text-text-muted">
        このカテゴリにはまだ記事がありません。
      </p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedPosts.map((post) => (
          <BlogCard
            id={post.id}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            tags={post.data.tags}
            hero={post.data.hero}
          />
        ))}
      </div>
    )
  }
</Layout>
