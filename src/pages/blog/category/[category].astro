---
import Layout from "../../../layouts/Layout.astro"
import BlogCard from "../../../components/BlogCard.astro"
import Breadcrumb from "../../../components/Breadcrumb.astro"
import { getPublishedPosts, sortPostsByDate } from "../../../lib/posts"
import {
  ALL_CATEGORIES,
  CATEGORY_LABELS,
  CATEGORY_DESCRIPTIONS,
  SITE_NAME,
} from "../../../lib/constants"

export async function getStaticPaths() {
  return ALL_CATEGORIES.map((category) => ({
    params: { category },
  }))
}

const { category } = Astro.params
const categoryLabel = CATEGORY_LABELS[category] ?? category
const categoryDescription = CATEGORY_DESCRIPTIONS[category] ?? ""

const allPosts = await getPublishedPosts()
const sortedPosts = sortPostsByDate(
  allPosts.filter((post) => post.data.category === category),
)
---

<Layout
  title={`${categoryLabel}の記事一覧`}
  description={`${SITE_NAME}の${categoryLabel}カテゴリの記事一覧。${categoryDescription}`}
>
  <Breadcrumb
    items={[
      { name: "ホーム", href: "/" },
      { name: "記事一覧", href: "/blog" },
      { name: categoryLabel },
    ]}
  />

  <h1 class="text-3xl font-bold mb-4">{categoryLabel}</h1>
  <p class="text-text-secondary mb-8">{categoryDescription}</p>

  {
    sortedPosts.length === 0 ? (
      <p class="text-text-muted">このカテゴリにはまだ記事がありません。</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedPosts.map((post) => (
          <BlogCard
            id={post.id}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            tags={post.data.tags}
            hero={post.data.hero}
          />
        ))}
      </div>
    )
  }
</Layout>
