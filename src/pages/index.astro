---
import Layout from "../layouts/Layout.astro"
import BlogCard from "../components/BlogCard.astro"
import { getPublishedPosts, sortPostsByDate } from "../lib/posts"

const allPosts = await getPublishedPosts()
const recentPosts = sortPostsByDate(allPosts).slice(0, 6)
---

<Layout title="ホーム">
  <section class="mb-12">
    <div class="text-center mb-8">
      <h1 class="text-4xl font-bold mb-4">
        <span class="text-accent">Deadlock</span> 攻略ブログ
      </h1>
      <p class="text-text-secondary text-lg">
        最新メタ情報、ヒーローガイド、パッチノート解説
      </p>
    </div>
  </section>

  <section>
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold">最新記事</h2>
      <a
        href="/blog"
        class="text-accent hover:text-accent-hover transition-colors text-sm"
      >
        すべての記事を見る &rarr;
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        recentPosts.map((post) => (
          <BlogCard
            id={post.id}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            tags={post.data.tags}
            hero={post.data.hero}
          />
        ))
      }
    </div>
  </section>
</Layout>
