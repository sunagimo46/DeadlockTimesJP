---
import JsonLd from "./JsonLd.astro"

interface BreadcrumbItem {
  name: string
  href?: string
}

interface Props {
  items: BreadcrumbItem[]
}

const { items } = Astro.props
const siteUrl = "https://deadlock-guide.netlify.app"

const breadcrumbListData: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: items.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.name,
    ...(item.href ? { item: `${siteUrl}${item.href}` } : {}),
  })),
}
---

<nav aria-label="パンくずリスト" class="mb-6 text-sm text-text-muted">
  <ol class="flex flex-wrap items-center gap-1">
    {
      items.map((item, index) => (
        <li class="flex items-center gap-1">
          {index > 0 && <span aria-hidden="true">/</span>}
          {item.href ? (
            <a
              href={item.href}
              class="hover:text-accent transition-colors"
            >
              {item.name}
            </a>
          ) : (
            <span class="text-text-secondary">{item.name}</span>
          )}
        </li>
      ))
    }
  </ol>
</nav>

<JsonLd data={breadcrumbListData} />
