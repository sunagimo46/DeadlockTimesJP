---
import { ALL_CATEGORIES, CATEGORY_LABELS } from "../lib/constants"

const categories = [
  { value: "all" as const, label: "すべて" },
  ...ALL_CATEGORIES.map((cat) => ({ value: cat, label: CATEGORY_LABELS[cat] })),
]
---

<div class="flex flex-wrap gap-2 mb-8">
  {
    categories.map((cat) => (
      <a
        href={cat.value === "all" ? "/blog" : `/blog/category/${cat.value}`}
        class="px-3 py-1 text-sm rounded-full border border-border text-text-secondary hover:border-accent hover:text-accent transition-colors"
      >
        {cat.label}
      </a>
    ))
  }
</div>
