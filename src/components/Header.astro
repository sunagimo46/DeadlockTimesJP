---
import { CATEGORY_LABELS } from "../lib/constants"

const navItems = [
  { label: "ホーム", href: "/" },
  { label: "記事一覧", href: "/blog" },
  { label: CATEGORY_LABELS["hero-guide"], href: "/blog/category/hero-guide" },
  { label: CATEGORY_LABELS["patch-notes"], href: "/blog/category/patch-notes" },
]
---

<header class="border-b border-border bg-bg-secondary">
  <nav class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
    <a
      href="/"
      class="hover:text-accent-hover transition-colors leading-tight"
    >
      <span class="block text-xl font-bold text-accent">DeadlockTimesJP</span>
      <span class="block text-xs text-text-muted">Deadlock攻略ブログ</span>
    </a>

    <div class="hidden md:flex items-center gap-6">
      <ul class="flex gap-6">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-text-secondary hover:text-text-primary transition-colors"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <a
        href="/search"
        class="text-text-secondary hover:text-text-primary transition-colors"
        aria-label="検索"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 h-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"
          ></path>
        </svg>
      </a>
    </div>

    <div class="md:hidden flex items-center gap-2">
      <a
        href="/search"
        class="p-2 text-text-secondary hover:text-text-primary transition-colors"
        aria-label="検索"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 h-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"
          ></path>
        </svg>
      </a>
      <details class="relative">
        <summary
        class="list-none cursor-pointer p-2 text-text-secondary hover:text-text-primary transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-6 h-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </summary>
      <ul
        class="absolute right-0 top-full mt-2 w-48 bg-bg-secondary border border-border rounded-lg shadow-lg py-2 z-50"
      >
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="block px-4 py-2 text-text-secondary hover:text-text-primary hover:bg-bg-hover transition-colors"
              >
                {item.label}
              </a>
            </li>
          ))
        }
        </ul>
      </details>
    </div>
  </nav>
</header>
