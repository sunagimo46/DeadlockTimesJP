---
import { CATEGORY_LABELS, CATEGORY_COLORS } from "../lib/constants"

interface Props {
  id: string
  title: string
  description: string
  pubDate: Date
  category: string
  tags: string[]
  hero?: string
}

const { id, title, description, pubDate, category, tags } = Astro.props

const formattedDate = pubDate.toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
})
---

<article
  class="bg-bg-card rounded-lg border border-border hover:border-border-hover transition-colors p-6"
>
  <a href={`/blog/${id}`} class="block mb-4">
    <div class="flex items-center gap-3 mb-3">
      <span
        class={`text-xs font-semibold ${CATEGORY_COLORS[category] ?? "text-text-secondary"}`}
      >
        {CATEGORY_LABELS[category] ?? category}
      </span>
      <time class="text-xs text-text-muted" datetime={pubDate.toISOString()}>
        {formattedDate}
      </time>
    </div>
    <h2
      class="text-lg font-bold text-text-primary mb-2 hover:text-accent transition-colors"
    >
      {title}
    </h2>
    <p class="text-sm text-text-secondary line-clamp-2">
      {description}
    </p>
  </a>
  <div class="flex flex-wrap gap-2">
    {
      tags.map((tag) => (
        <a
          href={`/blog/tags/${tag}`}
          class="text-xs bg-accent-subtle text-accent px-2 py-1 rounded hover:bg-accent hover:text-bg-primary transition-colors"
        >
          {tag}
        </a>
      ))
    }
  </div>
</article>
