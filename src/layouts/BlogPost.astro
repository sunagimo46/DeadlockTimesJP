---
import Layout from "./Layout.astro"
import Breadcrumb from "../components/Breadcrumb.astro"
import BlogPostJsonLd from "../components/BlogPostJsonLd.astro"
import { CATEGORY_LABELS } from "../lib/constants"
import type { CollectionEntry } from "astro:content"

interface Props {
  entry: CollectionEntry<"blog">
}

const { entry } = Astro.props
const { title, description, pubDate, updatedDate, tags, category, hero } =
  entry.data

const formattedPubDate = pubDate.toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
})
---

<Layout
  title={title}
  description={description}
  ogType="article"
  publishedTime={pubDate.toISOString()}
  modifiedTime={updatedDate?.toISOString()}
  tags={tags}
>
  <BlogPostJsonLd
    title={title}
    description={description}
    url={Astro.url.href}
    publishedDate={pubDate}
    modifiedDate={updatedDate}
    tags={tags}
    category={category}
  />
  <article class="max-w-3xl mx-auto">
    <Breadcrumb
      items={[
        { name: "ホーム", href: "/" },
        { name: "記事一覧", href: "/blog" },
        {
          name: CATEGORY_LABELS[category] ?? category,
          href: `/blog/category/${category}`,
        },
        { name: title },
      ]}
    />
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-semibold text-accent">
          {CATEGORY_LABELS[category] ?? category}
        </span>
        <time
          class="text-xs text-text-muted"
          datetime={pubDate.toISOString()}
        >
          {formattedPubDate}
        </time>
        {
          updatedDate && (
            <span class="text-xs text-text-muted">
              （更新: {updatedDate.toLocaleDateString("ja-JP")}）
            </span>
          )
        }
      </div>
      <h1 class="text-3xl font-bold mb-4">{title}</h1>
      {hero && <p class="text-text-secondary">関連ヒーロー: {hero}</p>}
      <div class="flex flex-wrap gap-2 mt-4">
        {
          tags.map((tag) => (
            <a
              href={`/blog/tags/${tag}`}
              class="text-xs bg-accent-subtle text-accent px-2 py-1 rounded hover:bg-accent hover:text-bg-primary transition-colors"
            >
              {tag}
            </a>
          ))
        }
      </div>
    </header>
    <div class="prose max-w-none">
      <slot />
    </div>
  </article>
</Layout>
